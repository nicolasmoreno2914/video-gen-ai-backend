{
  "name": "video-engine-ia-backend",
  "version": "1.0.0",
  "description": "Video Engine IA — Backend NestJS",
  "scripts": {
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "start:worker": "node dist/worker",
    "build": "nest build",
    "migration:run": "typeorm migration:run -d dist/config/datasource.js",
    "migration:generate": "typeorm migration:generate src/modules/database/migrations/migration -d src/config/datasource.ts",
    "seed": "ts-node -r tsconfig-paths/register src/modules/database/seeds/default-institution.seed.ts",
    "get-youtube-token": "ts-node -r tsconfig-paths/register src/scripts/get-youtube-token.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@nestjs/bullmq": "^10.2.0",
    "@nestjs/cli": "^10.3.2",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/event-emitter": "^2.0.4",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/schedule": "^4.0.1",
    "@nestjs/typeorm": "^10.0.2",
    "@supabase/supabase-js": "^2.105.3",
    "axios": "^1.6.7",
    "bullmq": "^5.4.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "fluent-ffmpeg": "^2.1.2",
    "googleapis": "^132.0.0",
    "ioredis": "^5.3.2",
    "nest-winston": "^1.9.4",
    "openai": "^4.29.0",
    "p-limit": "^4.0.0",
    "pg": "^8.11.3",
    "puppeteer": "^21.11.0",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20",
    "uuid": "^9.0.1",
    "winston": "^3.12.0",
    "winston-daily-rotate-file": "^5.0.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3",
    "ws": "^8.20.0",
    "@types/express": "^4.17.21",
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/node": "^20.11.20",
    "@types/pg": "^8.11.2",
    "@types/uuid": "^9.0.8",
    "@types/ws": "^8.18.1"
  },
  "devDependencies": {
    "@nestjs/schematics": "^10.1.1"
  }
}
